# --- Managed by MAS-HPC Ansible (Slurm 23.11) ---
ClusterName=mas_hpc_cluster
ControlMachine=master
ControlAddr={{ hostvars['master']['ansible_host'] }}

# Accounting Storage
AccountingStorageType=accounting_storage/slurmdbd
AccountingStorageHost=master
JobAcctGatherType=jobacct_gather/linux

# --- Dynamic Node Definitions ---
{% for host in groups['computes'] %}
NodeName={{ host }} NodeAddr={{ hostvars[host]['ansible_host'] }} CPUs=2 State=UNKNOWN
{% endfor %}

# Submit-only login node
NodeName=login NodeAddr={{ hostvars['login']['ansible_host'] }} CPUs=2 State=UNKNOWN

# Partition Configuration
PartitionName=debug Nodes=compute[1-3],login Default=YES MaxTime=INFINITE State=UP